{
  "name": "flux-tts",
  "version": "0.3.4",
  "description": "Obsidian plugin that records audio and creates Groq-powered transcription notes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "test": "node test.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "transcription",
    "speech-to-text",
    "groq"
  ],
  "author": "smbp",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.25.0",
    "obsidian": "latest",
    "typescript": "^5.7.0"
  },
  "allowScripts": {
    "esbuild@0.25.12": true
  }
}
